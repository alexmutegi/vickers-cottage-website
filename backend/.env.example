# Server
PORT=5000
NODE_ENV=development

# Database (Supabase PostgreSQL)
DB_HOST=db.xxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_password
DATABASE_URL=postgresql://postgres:your_password@db.xxxx.supabase.co:5432/postgres

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL(s) for CORS — comma-separated list allowed
# e.g. https://your-app.vercel.app,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# M-Pesa Daraja API (Phase 6)
# Get credentials from https://developer.safaricom.co.ke
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey_here
MPESA_CALLBACK_URL=https://your-api.onrender.com/api/mpesa/callback

# Logging (Phase 7)
LOG_LEVEL=info

# Rate limiting (Phase 7) — max requests per 15 min window
RATE_LIMIT_MAX=300

# Sentry error monitoring (Phase 7)
# Get DSN from https://sentry.io (free tier available)
# Leave blank to disable
SENTRY_DSN=

# DB pool tuning (Phase 7)
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_IDLE_TIMEOUT=30000
